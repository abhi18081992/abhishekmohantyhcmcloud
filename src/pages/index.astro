---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const formatShort = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Pick a pill color for a tag deterministically
const tagColor = (tag: string): string => {
  const t = tag.toLowerCase();
  if (t.includes('fast formula') || t.includes('fastformula')) return 'red';
  if (t.includes('null') || t.includes('default')) return 'orange';
  if (t.includes('advanced') || t.includes('intermediate') || t.includes('beginner')) return 'navy';
  if (t.includes('hdl') || t.includes('benefits') || t.includes('recruit')) return 'purple';
  // Hash fallback for consistency
  const hash = t.split('').reduce((a, c) => a + c.charCodeAt(0), 0);
  return ['red', 'orange', 'navy', 'purple'][hash % 4];
};

// Primary category for the eyebrow on each card
const primaryCategory = (tags: string[], title: string): string => {
  const all = (tags.join(' ') + ' ' + title).toLowerCase();
  if (all.includes('hdl')) return 'HDL';
  if (all.includes('benefit')) return 'Benefits';
  if (all.includes('recruit')) return 'Recruiting';
  if (all.includes('absence')) return 'Absence';
  if (all.includes('time and labor') || all.includes('tcr') || all.includes('ter')) return 'Time & Labor';
  if (tags.length > 0) return tags[0];
  return 'Fast Formula';
};
---

<BaseLayout title="Home">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
      </div>
      <div class="hero-content">
        <p class="eyebrow">Oracle HCM Cloud</p>
        <h1>Abhishek Mohanty</h1>
        <p class="hero-tagline">
          Technical deep-dives into Oracle HCM Cloud — Fast Formulas, HDL, Benefits &amp; beyond.
        </p>
        <div class="hero-meta">
          <span class="meta-dot"></span>
          <span>Published from India · Read in 30+ countries</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="articles container">
    <header class="articles-header">
      <h2>Articles</h2>
      <p class="articles-sub">Technical guides, deep-dives, and practical solutions.</p>
    </header>

    <nav class="filter-row" aria-label="Categories">
      <a href="/" class="pill-outline is-active">All</a>
      <a href="/tags/fast-formula" class="pill-outline">Fast Formula</a>
      <a href="/tags/benefits" class="pill-outline">Benefits</a>
      <a href="/tags/hdl" class="pill-outline">HDL</a>
      <a href="/tags/recruiting" class="pill-outline">Recruiting</a>
      <a href="/tags/null-handling" class="pill-outline">Null Handling</a>
    </nav>

    {allPosts.length === 0 ? (
      <div class="empty">
        <p class="muted">No posts published yet.</p>
      </div>
    ) : (
      <div class="card-grid">
        {allPosts.map((post) => {
          const category = primaryCategory(post.data.tags, post.data.title);
          return (
            <a href={`/posts/${post.slug}`} class="card">
              <div class="card-top">
                <span class="card-category">{category}</span>
                <span class="card-date">{formatShort(post.data.pubDate)}</span>
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>
              <h3 class="card-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="card-desc">{post.data.description}</p>
              )}
              {post.data.tags.length > 0 && (
                <div class="card-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class={`pill pill-${tagColor(tag)}`}>{tag}</span>
                  ))}
                </div>
              )}
              <div class="card-foot">
                <time>{formatDate(post.data.pubDate)}</time>
                <span class="dot">·</span>
                <span>Oracle HCM Cloud</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .hero-inner {
    position: relative;
    padding-block: clamp(4rem, 10vw, 7rem);
    text-align: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }
  .hero-shape-1 {
    width: 360px; height: 360px;
    background: radial-gradient(circle, var(--orange-soft), transparent);
    top: -100px; left: 10%;
  }
  .hero-shape-2 {
    width: 420px; height: 420px;
    background: radial-gradient(circle, var(--red-soft), transparent);
    bottom: -150px; right: 5%;
  }
  .hero-shape-3 {
    width: 280px; height: 280px;
    background: radial-gradient(circle, #fef9e7, transparent);
    top: 30%; left: 50%;
    transform: translateX(-50%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin-inline: auto;
  }
  .hero-content .eyebrow {
    margin-bottom: 1.2em;
  }
  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 0.5em;
    color: var(--ink-strong);
  }
  .hero-tagline {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: var(--ink-muted);
    line-height: 1.55;
    max-width: 38ch;
    margin: 0 auto 2rem;
  }
  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-display);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    font-weight: 500;
  }
  .meta-dot {
    width: 6px; height: 6px;
    background: var(--orange);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(230,126,34,0.18);
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(230,126,34,0.18); }
    50% { box-shadow: 0 0 0 7px rgba(230,126,34,0.04); }
  }

  /* ARTICLES */
  .articles {
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .articles-header {
    margin-bottom: 1.5rem;
    text-align: left;
  }
  .articles-header h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0 0 0.3em;
    border: none;
    padding: 0;
  }
  .articles-sub {
    color: var(--ink-muted);
    font-size: 1.05rem;
    margin: 0;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* CARD GRID */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 760px) {
    .card-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  }
  .card {
    display: block;
    padding: 1.75rem 1.85rem 1.6rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--ink-strong);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    text-decoration: none;
    position: relative;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(26,26,26,0.08);
    border-color: var(--border-strong);
    border-bottom-color: var(--border-strong);
  }
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.9rem;
  }
  .card-category {
    display: inline-block;
    background: var(--orange-soft);
    color: var(--orange-dark);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.35em 0.85em;
    border-radius: 999px;
  }
  .card-date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .card-arrow {
    margin-left: auto;
    font-size: 1.2rem;
    color: var(--ink-faint);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .card:hover .card-arrow {
    color: var(--orange);
    transform: translate(2px, -2px);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.32rem;
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.018em;
    margin: 0 0 0.65em;
    color: var(--ink-strong);
  }
  .card-desc {
    font-size: 0.94rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin: 0 0 1.1em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 1em;
  }
  .card-foot {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    padding-top: 0.85rem;
    border-top: 1px solid var(--border);
  }
  .card-foot .dot { margin: 0 0.5em; }

  .empty {
    padding-block: 4rem;
    text-align: center;
  }
</style>
