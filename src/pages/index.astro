---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = allPosts;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Group by year for the archive list
const postsByYear: Record<string, typeof rest> = {};
for (const post of rest) {
  const year = post.data.pubDate.getFullYear().toString();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
}
const years = Object.keys(postsByYear).sort((a, b) => parseInt(b) - parseInt(a));
---

<BaseLayout title="Home">
  <section class="hero container">
    <div class="hero-grid">
      <div class="hero-intro">
        <p class="eyebrow">Field Notes</p>
        <h1>
          Working notes from the<br />
          <em>Oracle HCM Cloud</em> trenches.
        </h1>
        <p class="hero-lede">
          Fast Formulas that survived production. Edge cases nobody documented.
          Multi-country APAC patterns from a decade in the techno-functional weeds.
        </p>
        <div class="hero-meta">
          <span class="meta-dot"></span>
          <span>Published from India · Read in 30+ countries</span>
        </div>
      </div>
      <aside class="hero-card">
        <p class="card-label">Currently Writing About</p>
        <ul class="topic-list">
          <li>Absence Management formulas</li>
          <li>Time and Labor (TER &amp; TCR)</li>
          <li>Redwood &amp; HDL Transformation</li>
          <li>Multi-country APAC patterns</li>
          <li>Debug logging idioms</li>
        </ul>
      </aside>
    </div>
  </section>

  {featured && (
    <section class="featured container">
      <p class="section-label">Latest</p>
      <a href={`/posts/${featured.slug}`} class="featured-card">
        {featured.data.module && <p class="eyebrow">{featured.data.module}</p>}
        <h2>{featured.data.title}</h2>
        {featured.data.description && <p class="featured-desc">{featured.data.description}</p>}
        <p class="featured-meta">
          <time>{formatDate(featured.data.pubDate)}</time>
          {featured.data.tags.length > 0 && (
            <>
              <span class="dot">·</span>
              <span>{featured.data.tags.slice(0, 3).join(' · ')}</span>
            </>
          )}
        </p>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="archive container">
      <p class="section-label">Archive</p>
      {years.map((year) => (
        <div class="year-block">
          <h3 class="year-heading">{year}</h3>
          <ul class="archive-list">
            {postsByYear[year].map((post) => (
              <li>
                <a href={`/posts/${post.slug}`}>
                  <time>{formatDate(post.data.pubDate)}</time>
                  <span class="archive-title">{post.data.title}</span>
                  {post.data.module && <span class="archive-module">{post.data.module}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  )}

  {allPosts.length === 0 && (
    <section class="container empty">
      <p class="muted">No posts yet. Run the migration script to import from Blogger.</p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--border);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .hero-intro h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    line-height: 1.05;
    margin: 0.4em 0 0.8em;
    font-weight: 500;
  }
  .hero-intro h1 em {
    color: var(--accent);
    font-style: italic;
  }
  .hero-lede {
    font-size: 1.15rem;
    color: var(--ink-muted);
    max-width: 55ch;
    line-height: 1.6;
    font-family: var(--font-display);
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.6em;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .meta-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(192,57,43,0.15);
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(192,57,43,0.15); }
    50% { box-shadow: 0 0 0 6px rgba(192,57,43,0.05); }
  }
  .hero-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    padding: 1.75rem;
    position: relative;
  }
  .hero-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    right: -1px;
    height: 3px;
    background: var(--accent);
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0 0 1em;
  }
  .topic-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .topic-list li {
    font-family: var(--font-display);
    font-size: 1rem;
    padding: 0.55em 0;
    border-bottom: 1px dashed var(--border);
    color: var(--ink);
  }
  .topic-list li:last-child { border-bottom: none; }

  /* Section labels */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 1.5em;
    padding-bottom: 0.6em;
    border-bottom: 1px solid var(--border);
  }

  /* Featured post */
  .featured { padding-block: var(--section-y); }
  .featured-card {
    display: block;
    padding: 2.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    color: var(--ink);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .featured-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(26,26,26,0.08);
    border-color: var(--border-strong);
  }
  .featured-card h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 0.3em 0 0.5em;
    border: none;
    padding: 0;
  }
  .featured-desc {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 0 1em;
    font-family: var(--font-display);
    font-style: italic;
  }
  .featured-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  .dot { margin: 0 0.5em; }

  /* Archive */
  .archive { padding-block: var(--section-y); }
  .year-block { margin-bottom: 3rem; }
  .year-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink-faint);
    margin: 0 0 1em;
    border: none;
    padding: 0;
  }
  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .archive-list li {
    border-bottom: 1px solid var(--border);
  }
  .archive-list a {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1em 0;
    color: var(--ink);
    border: none;
    transition: padding 0.2s ease;
  }
  .archive-list a:hover {
    padding-left: 0.5rem;
  }
  .archive-list a:hover .archive-title {
    color: var(--accent);
  }
  .archive-list time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    text-transform: uppercase;
  }
  .archive-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .archive-module {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    border: 1px solid var(--border-strong);
    padding: 0.25em 0.6em;
  }

  .empty {
    padding-block: 4rem;
    text-align: center;
  }

  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .archive-list a {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding: 1.1em 0;
    }
    .archive-module { justify-self: start; margin-top: 0.4em; }
  }
</style>
