---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="bio">
      <p class="bio-headline">Abhishek Mohanty</p>
      <p class="bio-text">
        Oracle HCM Cloud Technical Lead, <strong>Oracle ACE Apprentice</strong>, and member of the
        <strong>All India Oracle Users Group (AIOUG)</strong>. Over a decade of techno-functional work
        across Fast Formulas, Absence Management, Time and Labor, Core HR, Redwood, HDL, and OTBI —
        with deep delivery experience across the APAC region.
      </p>
    </div>
    <div class="meta">
      <p class="copy">© {year} Abhishek Mohanty</p>
      <p class="links">
        <a href="/rss.xml">RSS</a>
        <span class="sep">·</span>
        <a href="/sitemap-index.xml">Sitemap</a>
        <span class="sep">·</span>
        <a href="/about">About</a>
      </p>
      <p class="disclaimer">
        Notes are personal and reflect the author's views, not those of any employer or client.
        Oracle and the Oracle product names referenced are trademarks of Oracle Corporation.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
    padding-block: 3rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
  }
  .bio-headline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5em;
    color: var(--ink);
  }
  .bio-text {
    font-size: 0.92rem;
    color: var(--ink-muted);
    line-height: 1.7;
    margin: 0;
  }
  .meta {
    text-align: right;
  }
  .copy {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    margin: 0 0 0.5em;
  }
  .links {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1em;
  }
  .links a {
    color: var(--ink-muted);
    border: none;
  }
  .links a:hover { color: var(--accent); }
  .sep { color: var(--ink-faint); margin: 0 0.5em; }
  .disclaimer {
    font-size: 0.72rem;
    color: var(--ink-faint);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
    .meta { text-align: left; }
  }
</style>
