---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark">AM</span>
        <span class="brand-name">Abhishek Mohanty</span>
      </a>
      <p class="bio">
        Oracle HCM Cloud Technical Lead. <strong>Oracle ACE Apprentice</strong> and member of the
        <strong>All India Oracle Users Group (AIOUG)</strong>.
      </p>
    </div>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <div class="footer-legal">
      <p>© {year} Abhishek Mohanty. All rights reserved.</p>
      <p class="disclaimer">
        Notes are personal and reflect the author's views, not those of any employer or client.
        Oracle and the Oracle product names referenced are trademarks of Oracle Corporation.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
    padding-block: 3rem 2rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2.5rem;
    padding-bottom: 1.5rem;
  }
  .footer-brand .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--ink-strong);
    border: none;
    margin-bottom: 1rem;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--bg-dark);
    color: white;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.78rem;
    border-radius: 50%;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
  }
  .bio {
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
    max-width: 50ch;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: flex-end;
  }
  .footer-links a {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-muted);
    border: none;
  }
  .footer-links a:hover { color: var(--ink); }
  .footer-legal {
    grid-column: 1 / -1;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    color: var(--ink-faint);
    font-size: 0.78rem;
    line-height: 1.6;
  }
  .footer-legal p { margin: 0 0 0.3em; }
  .disclaimer { font-style: italic; }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .footer-links { justify-content: flex-start; }
  }
</style>
